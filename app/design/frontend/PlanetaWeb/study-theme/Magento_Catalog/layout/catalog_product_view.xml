<?xml version="1.0"?>

<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <container name="product.info.additional" htmlTag="div" htmlClass="product-info-additional" before="product.info.main">
                <block class="Magento\Framework\View\Element\Template"  name="product.custom.popup" after="product.info.stock.sku" template="Magento_Catalog::custom-poup.phtml">
                    <block class="Magento\Framework\View\Element\Template" name="product.custom.popup.content" template="Magento_Catalog::custom-poup-content.phtml"/>
                </block>
            </container>
        </referenceContainer>

        <move element="page.main.title" destination="product.info.additional" before="-"/>
        <move element="product.info.stock.sku" destination="product.info.additional" after="page.main.title"/>
        <move element="product.info.media" destination="product.info.additional" after="product.custom.popup"/>
    </body>
</page>
