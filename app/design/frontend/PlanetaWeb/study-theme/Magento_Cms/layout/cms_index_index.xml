<?xml version="1.0"?>

<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block class="Magento\Cms\Block\Block" name="homepage_carousel">
                <arguments>
                    <argument name="block_id" xsi:type="string">slick-carousel</argument>
                </arguments>
            </block>

            <block class="Magento\Framework\View\Element\Template"  name="custom.homepage.heading" after="homepage_carousel" template="Magento_Theme::custom-heading.phtml"/>
            <block class="Magento\Framework\View\Element\Template"  name="custom.homepage.text" after="custom.homepage.heading" template="Magento_Theme::custom-text.phtml"/>
        </referenceContainer>

        <referenceContainer name="sidebar.main">
            <block class="Magento\Framework\View\Element\Template"  name="custom.homepage.heading" before="-" template="Magento_Cms::sidebar-tabs.phtml"/>
        </referenceContainer>
    </body>
</page>
